<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Phoebe</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>

	<!-- Usage descriptions — shown in system permission prompts. Apple
	     rejects builds missing these when the corresponding API is
	     referenced. Copy here must match the feature in context. -->
	<key>NSContactsUsageDescription</key>
	<string>Phoebe uses your contacts so you can invite people you already know — just like a party app. Nothing is sent to our servers unless you choose to invite someone.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Phoebe uses Face ID so only you can open your prayer intentions.</string>
	<key>NSCameraUsageDescription</key>
	<string>Phoebe uses your camera so you can take a profile photo.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Phoebe uses your photos so you can choose a profile picture.</string>

	<!-- Background modes — push needs "remote-notification" for silent
	     wake-up on data pushes. Bell scheduling uses it too. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- iOS 17+ asks for permission to use non-public APIs even for
	     simple defaults like UserDefaults. Our PrivacyInfo.xcprivacy
	     covers the formal declaration; this entry covers the audit. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Home-screen quick actions (long-press the app icon).
	     Static shortcuts ship in Info.plist so they're always
	     present without runtime registration. AppDelegate's
	     `application(_:performActionFor:completionHandler:)` maps
	     each `UIApplicationShortcutItemType` to a deep-link path
	     by posting the matching universal-link URL through the
	     existing native-shell appUrlOpen path — same routing
	     mechanism the rest of the deep-link wiring uses. -->
	<key>UIApplicationShortcutItems</key>
	<array>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>app.withphoebe.mobile.shortcut.prayer-list</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Begin prayer list</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Walk through today's prayers</string>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeFavorite</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>app.withphoebe.mobile.shortcut.prayer-request-new</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>New prayer request</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>Share what to carry</string>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeAdd</string>
		</dict>
		<dict>
			<key>UIApplicationShortcutItemType</key>
			<string>app.withphoebe.mobile.shortcut.letter-new</string>
			<key>UIApplicationShortcutItemTitle</key>
			<string>Write a letter</string>
			<key>UIApplicationShortcutItemSubtitle</key>
			<string>To one friend</string>
			<key>UIApplicationShortcutItemIconType</key>
			<string>UIApplicationShortcutIconTypeCompose</string>
		</dict>
	</array>
</dict>
</plist>
