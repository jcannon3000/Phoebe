<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications: required for APNs device tokens.
	     Must be "production" for TestFlight + App Store. The previous
	     comment here ("App Store builds use production automatically")
	     was incorrect — Apple does NOT switch this at archive/upload
	     time; whatever's in the entitlement is what ships. With
	     "development" set, TestFlight builds got sandbox tokens while
	     the server (which defaults APNS_ENVIRONMENT=production) posted
	     to api.push.apple.com → 400 BadDeviceToken → row invalidated
	     → every subsequent push silently skipped.
	     For local Xcode debug-on-device, temporarily flip this to
	     "development" AND set APNS_ENVIRONMENT=sandbox in api-server
	     env, or just test pushes on a TestFlight build. -->
	<key>aps-environment</key>
	<string>production</string>

	<!-- Sign in with Apple: mandatory under Apple Guideline 4.8 since
	     Phoebe offers Google SSO. Enable this capability in Xcode on
	     the App ID and in the entitlements file (here). -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>

	<!-- Associated Domains: opens withphoebe.app links directly in the
	     installed app (universal links). Requires the
	     apple-app-site-association file to be served at
	     https://withphoebe.app/.well-known/apple-app-site-association
	     (already wired in api-server/src/app.ts). -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:withphoebe.app</string>
	</array>

	<!-- App Groups: shared container between the main app and the
	     PhoebeWidget target (home-screen widget writes today's bell
	     time + lectio stage to this suiteName via UserDefaults). -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.app.withphoebe.mobile</string>
	</array>
</dict>
</plist>
